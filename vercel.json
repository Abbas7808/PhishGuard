{
  "version": 2,
  "buildCommand": "npm run build --prefix phishguard/client",
  "outputDirectory": "phishguard/client/dist",
  "installCommand": "npm install --prefix phishguard/client && npm install --prefix phishguard/server",
  "framework": "vite",
  "functions": {
    "phishguard/server/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/phishguard/server/index.js"
    }
  ]
}
